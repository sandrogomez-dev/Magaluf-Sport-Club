---
import { useTranslations, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const actions = [
  {
    label: t('common.whatsapp'),
    href: `https://wa.me/${club.whatsapp}`,
    external: true,
    bg: 'bg-[#25D366] hover:bg-[#1ebe5b] text-white',
    filled: true,
    svg: '<path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.163 5.335 5.5.0 12.05.0a11.821 11.821 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-1.616zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>',
  },
  {
    label: t('common.call'),
    href: `tel:${club.phone}`,
    external: false,
    bg: 'bg-navy hover:bg-brand-dark text-white',
    filled: false,
    svg: '<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.7 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.2a2 2 0 0 1 2.1-.5c.9.4 1.8.6 2.7.7a2 2 0 0 1 1.7 2z"/>',
  },
  {
    label: t('common.getDirections'),
    href: club.mapsLink,
    external: true,
    bg: 'bg-gold hover:bg-accent-dark text-navy',
    filled: false,
    svg: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>',
  },
];
---

<div id="fab" class="fixed bottom-5 right-5 z-40 flex flex-col items-end gap-3 sm:bottom-6 sm:right-6">
  <!-- Las tres acciones: en móvil ocultas hasta abrir; en escritorio siempre visibles -->
  <div id="fab-actions" class="flex flex-col items-end gap-3">
    {
      actions.map((a) => (
        <a
          href={a.href}
          target={a.external ? '_blank' : undefined}
          rel={a.external ? 'noopener noreferrer' : undefined}
          aria-label={a.label}
          title={a.label}
          class={`group flex items-center gap-0 overflow-hidden rounded-full shadow-xl ring-1 ring-black/5 transition-all hover:gap-2.5 hover:pr-5 ${a.bg}`}
        >
          <span class="grid shrink-0 place-items-center" style="height:3.25rem;width:3.25rem;">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill={a.filled ? 'currentColor' : 'none'}
              stroke={a.filled ? 'none' : 'currentColor'}
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={a.svg}
            />
          </span>
          <span class="max-w-0 whitespace-nowrap text-sm font-display font-bold opacity-0 transition-all duration-300 group-hover:max-w-[12rem] group-hover:opacity-100">
            {a.label}
          </span>
        </a>
      ))
    }
  </div>

  <!-- Botón único (solo móvil): abre/cierra las acciones -->
  <button
    id="fab-toggle"
    class="grid h-14 w-14 place-items-center rounded-full bg-navy text-white shadow-xl ring-1 ring-black/10 transition-transform active:scale-95 sm:hidden"
    aria-label={t('nav.contact')}
    aria-expanded="false"
    aria-controls="fab-actions"
  >
    <svg class="fab-icon-open" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z" />
    </svg>
    <svg class="fab-icon-close hidden" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 6 6 18M6 6l12 12" />
    </svg>
  </button>
</div>

<style>
  /* Móvil: las acciones ocultas hasta abrir el FAB */
  @media (max-width: 639px) {
    #fab:not([data-open='true']) #fab-actions {
      display: none;
    }
    #fab[data-open='true'] #fab-actions a {
      animation: fab-in 0.22s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    #fab[data-open='true'] #fab-actions a:nth-child(1) { animation-delay: 0.02s; }
    #fab[data-open='true'] #fab-actions a:nth-child(2) { animation-delay: 0.07s; }
    #fab[data-open='true'] #fab-actions a:nth-child(3) { animation-delay: 0.12s; }
  }
  @keyframes fab-in {
    from { opacity: 0; transform: translateY(10px) scale(0.85); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    #fab[data-open='true'] #fab-actions a { animation: none; }
  }
</style>

<script>
  const fab = document.getElementById('fab');
  const toggle = document.getElementById('fab-toggle');
  const iconOpen = toggle?.querySelector('.fab-icon-open');
  const iconClose = toggle?.querySelector('.fab-icon-close');

  const setOpen = (open: boolean) => {
    if (!fab || !toggle) return;
    fab.dataset.open = String(open);
    toggle.setAttribute('aria-expanded', String(open));
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  };

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    setOpen(fab?.dataset.open !== 'true');
  });

  // Cerrar al tocar fuera o al elegir una acción
  document.addEventListener('click', (e) => {
    if (fab && !fab.contains(e.target as Node)) setOpen(false);
  });
  document.getElementById('fab-actions')?.addEventListener('click', () => setOpen(false));
</script>
