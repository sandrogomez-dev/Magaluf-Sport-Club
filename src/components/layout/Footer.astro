---
import { Image } from 'astro:assets';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';
import { img } from '../../lib/images';

interface Props {
  lang: Lang;
  url: URL;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const nav = [
  { href: '/nosotros', label: t('nav.club') },
  { href: '/escuela', label: t('nav.school') },
  { href: '/metodo', label: t('nav.method') },
  { href: '/padel', label: t('nav.padel') },
  { href: '/futbol-7', label: t('nav.football') },
  { href: '/eventos', label: t('nav.events') },
  { href: '/contacto', label: t('nav.contact') },
];
---

<footer class="bg-ink text-white/80">
  <div class="mx-auto grid max-w-6xl gap-12 px-5 py-16 sm:px-8 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-3 font-display text-xl font-extrabold text-white">
        <Image src={img('logo.png')} alt="Magaluf Sport Club" width={96} height={84} class="h-12 w-auto" />
        Magaluf Sport Club
      </div>
      <p class="mt-4 max-w-sm leading-relaxed text-white/70">{t('footer.tagline')}</p>
      <a
        href={club.booking}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex rounded-full bg-brand px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-light"
      >
        {t('common.bookPlaytomic')}
      </a>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-widest text-white">
        {t('footer.explore')}
      </h3>
      <ul class="mt-4 space-y-2">
        {
          nav.map((item) => (
            <li>
              <a href={localizePath(lang, item.href)} class="transition-colors hover:text-white">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-widest text-white">
        {t('footer.contact')}
      </h3>
      <ul class="mt-4 space-y-2">
        <li><a href={`tel:${club.phone}`} class="hover:text-white">{club.phoneDisplay}</a></li>
        <li><a href={`mailto:${club.email}`} class="hover:text-white">{club.email}</a></li>
        <li class="text-white/60">{club.address}</li>
      </ul>
      <div class="mt-4">
        <a
          href={club.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 hover:text-white"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <line x1="17.5" y1="6.5" x2="17.5" y2="6.5"></line>
          </svg>
          Instagram
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-6xl flex-col gap-3 px-5 py-6 text-sm text-white/50 sm:flex-row sm:items-center sm:justify-between sm:px-8">
      <p>© {year} Magaluf Sport Club. {t('footer.rights')}</p>
      <nav class="flex flex-wrap gap-x-5 gap-y-2">
        <a href={localizePath(lang, '/aviso-legal')} class="hover:text-white">{t('legal.aviso')}</a>
        <a href={localizePath(lang, '/privacidad')} class="hover:text-white">{t('legal.privacy')}</a>
        <a href={localizePath(lang, '/cookies')} class="hover:text-white">{t('legal.cookies')}</a>
      </nav>
    </div>
  </div>
</footer>
