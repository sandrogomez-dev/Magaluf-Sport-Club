---
interface Props {
  code: 'es' | 'en' | 'de';
  class?: string;
}
const { code, class: className = '' } = Astro.props;
// Banderas pequeñas. EN usa Union Jack (mercado británico).
---

{
  code === 'es' && (
    <svg viewBox="0 0 3 2" class={`block overflow-hidden rounded-[2px] ${className}`} aria-hidden="true">
      <rect width="3" height="2" fill="#c60b1e" />
      <rect width="3" height="1" y="0.5" fill="#ffc400" />
    </svg>
  )
}
{
  code === 'de' && (
    <svg viewBox="0 0 3 2" class={`block overflow-hidden rounded-[2px] ${className}`} aria-hidden="true">
      <rect width="3" height="2" fill="#000" />
      <rect width="3" height="1.333" y="0.667" fill="#dd0000" />
      <rect width="3" height="0.667" y="1.333" fill="#ffce00" />
    </svg>
  )
}
{
  code === 'en' && (
    <svg viewBox="0 0 60 30" class={`block overflow-hidden rounded-[2px] ${className}`} aria-hidden="true">
      <rect width="60" height="30" fill="#012169" />
      <path d="M0 0l60 30M60 0L0 30" stroke="#fff" stroke-width="6" />
      <path d="M0 0l60 30M60 0L0 30" stroke="#c8102e" stroke-width="4" />
      <path d="M30 0v30M0 15h60" stroke="#fff" stroke-width="10" />
      <path d="M30 0v30M0 15h60" stroke="#c8102e" stroke-width="6" />
    </svg>
  )
}
