---
import { Image } from 'astro:assets';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { img } from '../../lib/images';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-navy text-white grain">
  <Image
    src={img('aerial-golden.jpg')}
    alt=""
    widths={[768, 1280]}
    sizes="100vw"
    class="absolute inset-0 h-full w-full object-cover opacity-20"
    loading="lazy"
  />
  <div class="relative mx-auto max-w-3xl px-5 py-20 text-center sm:px-8 sm:py-28" data-reveal>
    <span class="inline-block rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold uppercase tracking-widest text-gold ring-1 ring-white/15">
      {t('holidays.eyebrow')}
    </span>
    <h2 class="mt-6 text-3xl font-extrabold sm:text-4xl md:text-5xl">{t('holidays.title')}</h2>
    <p class="mx-auto mt-3 inline-block rounded-full bg-gold px-4 py-1 text-sm font-bold uppercase tracking-wide text-navy">
      {t('holidays.badge')}
    </p>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-white/80">{t('holidays.desc')}</p>
    <a
      href={localizePath(lang, '/contacto')}
      class="mt-9 inline-flex items-center justify-center rounded-full bg-gold px-8 py-4 font-display text-lg font-bold text-navy transition-all hover:-translate-y-0.5 hover:bg-accent-dark"
    >
      {t('holidays.cta')}
    </a>
  </div>
</section>
