---
import { useTranslations, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-navy py-20 text-white sm:py-24 grain">
  <div class="relative mx-auto max-w-3xl px-5 text-center sm:px-8">
    <span class="eyebrow-line mx-auto w-fit text-sm font-semibold uppercase tracking-[0.2em] text-gold" data-reveal>
      {t('home.videoText')}
    </span>
    <h2 class="mx-auto mt-4 max-w-xl text-3xl font-extrabold sm:text-4xl" data-reveal>{t('home.videoTitle')}</h2>

    <div class="mx-auto mt-10 flex justify-center" data-reveal>
      <div class="relative aspect-[9/16] w-full max-w-[300px] overflow-hidden rounded-[1.75rem] bg-black shadow-2xl ring-4 ring-white/10">
        <video
          id="promo-video"
          class="h-full w-full object-cover"
          playsinline
          preload="none"
          poster="/video/promo-poster.jpg"
          controls
        >
          <source src="/video/promo.mp4" type="video/mp4" />
        </video>
        <button id="promo-play" class="absolute inset-0 grid place-items-center bg-navy/25 transition-opacity hover:bg-navy/10" aria-label="Play">
          <span class="grid h-16 w-16 place-items-center rounded-full bg-gold text-navy shadow-xl transition-transform hover:scale-105">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
          </span>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const v = document.getElementById('promo-video') as HTMLVideoElement | null;
  const btn = document.getElementById('promo-play') as HTMLButtonElement | null;
  if (v && btn) {
    btn.addEventListener('click', () => v.play());
    v.addEventListener('play', () => (btn.style.display = 'none'));
    v.addEventListener('pause', () => (btn.style.display = 'grid'));
  }
</script>
