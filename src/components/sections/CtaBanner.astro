---
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-navy grain">
  <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-gold/20 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-brand-light/30 blur-3xl"></div>
  <div class="relative mx-auto flex max-w-5xl flex-col items-center gap-6 px-5 py-20 text-center sm:px-8 sm:py-24" data-reveal>
    <h2 class="text-3xl font-extrabold text-white sm:text-5xl">{t('ctaBanner.title')}</h2>
    <p class="max-w-xl text-lg text-white/85">{t('ctaBanner.desc')}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={club.booking}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-gold px-8 py-4 font-display text-lg font-bold text-navy shadow-xl shadow-gold/25 transition-all hover:-translate-y-0.5 hover:bg-accent-dark"
      >
        {t('ctaBanner.primary')}
      </a>
      <a
        href={localizePath(lang, '/contacto')}
        class="inline-flex items-center justify-center rounded-full bg-white/10 px-8 py-4 font-display text-lg font-semibold text-white ring-1 ring-white/25 backdrop-blur transition-all hover:bg-white/20"
      >
        {t('ctaBanner.secondary')}
      </a>
    </div>
  </div>
</section>
