---
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="bg-brand">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-6 px-5 py-16 text-center sm:px-8 sm:py-20" data-reveal>
    <h2 class="text-3xl font-extrabold text-white sm:text-4xl">{t('ctaBanner.title')}</h2>
    <p class="max-w-xl text-lg text-white/85">{t('ctaBanner.desc')}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={club.booking}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 font-display text-lg font-semibold text-brand shadow-xl transition-all hover:-translate-y-0.5"
      >
        {t('ctaBanner.primary')}
      </a>
      <a
        href={localizePath(lang, '/contacto')}
        class="inline-flex items-center justify-center rounded-full bg-brand-dark px-8 py-4 font-display text-lg font-semibold text-white ring-1 ring-white/30 transition-all hover:-translate-y-0.5"
      >
        {t('ctaBanner.secondary')}
      </a>
    </div>
  </div>
</section>
