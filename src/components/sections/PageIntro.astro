---
import { Image } from 'astro:assets';
import { img, hasImg } from '../../lib/images';

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  image?: string;
}
const { eyebrow, title, intro, image } = Astro.props;
const withImage = image && hasImg(image);
---

<section class="relative flex min-h-[58vh] items-center overflow-hidden bg-navy pt-32 pb-16 text-white sm:pt-36 grain">
  {
    withImage && (
      <>
        <Image
          src={img(image!)}
          alt=""
          widths={[768, 1280, 1920]}
          sizes="100vw"
          class="absolute inset-0 h-full w-full object-cover opacity-35"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/70 to-navy/50" />
      </>
    )
  }
  <div class="relative mx-auto max-w-4xl px-5 text-center sm:px-8">
    {eyebrow && <span class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{eyebrow}</span>}
    <h1 class="mt-3 text-4xl font-extrabold sm:text-5xl md:text-6xl">{title}</h1>
    {intro && <p class="mx-auto mt-5 max-w-2xl text-lg text-white/85">{intro}</p>}
  </div>
</section>
