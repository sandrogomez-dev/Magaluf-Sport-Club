---
import { Image } from 'astro:assets';
import Section from '../ui/Section.astro';
import Heading from '../ui/Heading.astro';
import { useTranslations, type Lang } from '../../i18n/ui';
import { img } from '../../lib/images';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Mezcla de ambiente, comunidad y juego (los "personajes" funcionan aquí como vida del club).
const photos = [
  { name: 'terrace-night.jpg', span: 'sm:col-span-2 sm:row-span-2' },
  { name: 'events-group.jpg', span: '' },
  { name: 'coaches.jpg', span: '' },
  { name: 'bar-interior.jpg', span: '' },
  { name: 'padel-highfive.jpg', span: '' },
  { name: 'community-courtside.jpg', span: 'sm:row-span-2' },
  { name: 'community-women.jpg', span: '' },
  { name: 'aerial-golden.jpg', span: '' },
];
---

<Section bg="surface">
  <Heading eyebrow={t('gallery.title')} title={t('gallery.subtitle')} align="center" />

  <div class="mt-12 grid auto-rows-[180px] grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4">
    {
      photos.map((p, i) => (
        <figure
          class={`group relative overflow-hidden rounded-2xl bg-surface ${p.span}`}
          data-reveal
          style={`transition-delay:${i * 50}ms`}
        >
          <Image
            src={img(p.name)}
            alt=""
            widths={[300, 600, 900]}
            sizes="(min-width:640px) 25vw, 50vw"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </figure>
      ))
    }
  </div>
</Section>
