---
import { Image } from 'astro:assets';
import Section from '../ui/Section.astro';
import Heading from '../ui/Heading.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { img } from '../../lib/images';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const areas = [
  { href: '/nosotros', image: 'aerial-sign.jpg', icon: 'building', label: t('nav.club'), desc: t('home.clubDesc') },
  { href: '/padel', image: 'padel-doubles.jpg', icon: 'padel', label: t('nav.padel'), desc: t('home.padelDesc') },
  { href: '/futbol-7', image: 'football-aerial.jpg', icon: 'football', label: t('nav.football'), desc: t('home.footballDesc') },
  { href: '/eventos', image: 'events-group.jpg', icon: 'events', label: t('nav.events'), desc: t('home.eventsDesc') },
];
---

<Section bg="white">
  <Heading title={t('home.welcomeTitle')} intro={t('home.welcomeIntro')} align="center" />

  <div class="mt-12 grid gap-5 sm:grid-cols-2">
    {
      areas.map((a, i) => (
        <a
          href={localizePath(lang, a.href)}
          class="group relative flex h-64 flex-col justify-end overflow-hidden rounded-[1.5rem] bg-navy text-white shadow-sm ring-1 ring-navy/10 transition-all hover:-translate-y-1 hover:shadow-2xl hover:ring-gold"
          data-reveal
          style={`transition-delay:${i * 70}ms`}
        >
          <Image
            src={img(a.image)}
            alt={a.label}
            widths={[400, 800]}
            sizes="(min-width:640px) 50vw, 100vw"
            class="absolute inset-0 h-full w-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/40 to-transparent" />
          <div class="relative p-7">
            <span class="grid h-12 w-12 place-items-center rounded-full bg-white/15 text-gold backdrop-blur">
              <Icon name={a.icon} size={24} />
            </span>
            <h3 class="mt-4 font-display text-2xl font-bold">{a.label}</h3>
            <p class="mt-1 text-sm text-white/85">{a.desc}</p>
            <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-gold opacity-0 transition-all group-hover:opacity-100">
              {t('common.viewMore')}<Icon name="arrow" size={16} />
            </span>
          </div>
        </a>
      ))
    }
  </div>
</Section>
