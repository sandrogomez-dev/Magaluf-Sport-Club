---
import Section from '../ui/Section.astro';
import Heading from '../ui/Heading.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, getDict, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const items: { title: string; desc: string }[] = getDict(lang).why.items;
const icons = ['school', 'repeat', 'chip', 'users', 'badge', 'chart'];
---

<Section bg="white">
  <Heading eyebrow={t('why.eyebrow')} title={t('why.title')} intro={t('why.intro')} align="center" />

  <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      items.map((it, i) => (
        <div
          class="flex items-start gap-4 rounded-[1.25rem] bg-surface p-6 ring-1 ring-line/60 transition-all hover:-translate-y-1 hover:ring-gold"
          data-reveal
          style={`transition-delay:${i * 60}ms`}
        >
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-navy text-gold">
            <Icon name={icons[i] ?? 'check'} size={24} />
          </span>
          <div>
            <h3 class="font-display text-base font-bold text-ink">{it.title}</h3>
            <p class="mt-1 text-sm leading-snug text-muted">{it.desc}</p>
          </div>
        </div>
      ))
    }
  </div>
</Section>
