---
import { Image } from 'astro:assets';
import Section from '../ui/Section.astro';
import Heading from '../ui/Heading.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { img, hasImg } from '../../lib/images';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Bento asimétrico: pádel y café anchos; fútbol y eventos estrechos.
const services = [
  { key: 'padel', href: '/padel', image: 'padel-court-wide.jpg', icon: 'padel', span: 'lg:col-span-2' },
  { key: 'football', href: '/futbol-7', image: 'football-placeholder', icon: 'football', span: 'lg:col-span-1' },
  { key: 'events', href: '/eventos', image: 'events-group.jpg', icon: 'events', span: 'lg:col-span-1' },
  { key: 'cafe', href: '/nosotros', image: 'terrace-night.jpg', icon: 'cafe', span: 'lg:col-span-2' },
  { key: 'shop', href: '/contacto', image: 'shop.jpg', icon: 'shop', span: 'lg:col-span-3' },
];
---

<Section id="servicios" bg="surface">
  <Heading eyebrow={t('services.title')} title={t('services.subtitle')} align="center" />

  <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      services.map((s, i) => (
        <a
          href={localizePath(lang, s.href)}
          class={`group relative flex h-80 flex-col justify-end overflow-hidden rounded-[1.5rem] bg-navy text-white shadow-sm ring-1 ring-navy/10 transition-all hover:-translate-y-1 hover:shadow-2xl hover:ring-gold ${s.span}`}
          data-reveal
          style={`transition-delay:${i * 70}ms`}
        >
          {hasImg(s.image) ? (
            <Image
              src={img(s.image)}
              alt={t(`services.${s.key}.title`)}
              widths={[400, 800]}
              sizes="(min-width:1024px) 50vw, (min-width:640px) 50vw, 100vw"
              class="absolute inset-0 h-full w-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105"
            />
          ) : (
            <div class="absolute inset-0 bg-gradient-to-br from-navy via-brand-light to-navy" />
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/40 to-transparent" />

          <div class="relative p-7">
            <span class="grid h-12 w-12 place-items-center rounded-full bg-white/15 text-gold backdrop-blur">
              <Icon name={s.icon} size={24} />
            </span>
            <h3 class="mt-4 font-display text-2xl font-bold">{t(`services.${s.key}.title`)}</h3>
            <p class="mt-1 max-w-sm text-sm leading-snug text-white/85">{t(`services.${s.key}.desc`)}</p>
            <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-gold opacity-0 transition-all group-hover:opacity-100">
              {t('common.viewMore')}
              <Icon name="arrow" size={16} />
            </span>
          </div>
        </a>
      ))
    }
  </div>
</Section>
