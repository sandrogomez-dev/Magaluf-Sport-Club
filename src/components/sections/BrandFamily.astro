---
import Icon from '../ui/Icon.astro';
import { useTranslations, getDict, localizePath, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const items: { key: string; name: string; role: string; desc: string }[] = getDict(lang).brands.items;

const linkFor = (key: string) =>
  key === 'experience'
    ? { href: club.mpe, external: true }
    : key === 'method'
      ? { href: localizePath(lang, '/metodo'), external: false }
      : { href: localizePath(lang, '/nosotros'), external: false };
---

<section class="relative overflow-hidden bg-navy py-20 text-white sm:py-24 grain">
  <div class="relative mx-auto max-w-6xl px-5 sm:px-8">
    <div class="max-w-2xl" data-reveal>
      <span class="eyebrow-line text-sm font-semibold uppercase tracking-[0.2em] text-gold">{t('brands.eyebrow')}</span>
      <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl md:text-5xl">{t('brands.title')}</h2>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {
        items.map((b, i) => {
          const link = linkFor(b.key);
          const highlight = b.key === 'experience';
          return (
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
              class={`group flex flex-col rounded-[1.5rem] p-7 ring-1 transition-all hover:-translate-y-1 ${
                highlight ? 'bg-gold text-navy ring-gold' : 'bg-white/5 ring-white/10 hover:ring-gold'
              }`}
              data-reveal
              style={`transition-delay:${i * 80}ms`}
            >
              <span class={`text-xs font-bold uppercase tracking-widest ${highlight ? 'text-navy/70' : 'text-gold'}`}>{b.role}</span>
              <h3 class="mt-2 font-display text-xl font-extrabold leading-tight">{b.name}</h3>
              <p class={`mt-3 flex-1 text-sm leading-relaxed ${highlight ? 'text-navy/80' : 'text-white/75'}`}>{b.desc}</p>
              <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold">
                {link.external ? t('brands.visit') : t('common.viewMore')}
                <Icon name="arrow" size={15} />
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
