---
import { Image } from 'astro:assets';
import Icon from '../ui/Icon.astro';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';
import { img } from '../../lib/images';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative flex min-h-[92vh] items-center overflow-hidden bg-navy">
  <!-- Fondo aéreo del club con parallax -->
  <div id="hero-bg" class="absolute inset-0 will-change-transform">
    <Image
      src={img('aerial-hero.jpg')}
      alt="Magaluf Sport Club - vista aérea"
      widths={[768, 1280, 1920, 2400]}
      sizes="100vw"
      class="h-[115%] w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-br from-navy/90 via-navy/70 to-navy/45"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-transparent"></div>

  <div class="relative mx-auto w-full max-w-6xl px-5 pt-28 pb-16 sm:px-8">
    <div class="max-w-2xl text-white" data-reveal>
      <!-- 1) Logo protagonista (ya contiene el nombre del club) -->
      <Image src={img('logo.png')} alt="Magaluf Sport Club" width={240} height={210} class="h-28 w-auto sm:h-36" loading="eager" />

      <!-- 2) Pádel y fútbol 7 (título descriptivo, bueno para SEO) -->
      <h1 class="mt-6 text-2xl font-bold leading-tight text-white sm:text-3xl md:text-4xl">{t('hero.title')}</h1>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={localizePath(lang, '/padel')} class="inline-flex items-center gap-2 rounded-full bg-white/10 px-6 py-3 font-display font-semibold text-white ring-1 ring-white/25 backdrop-blur transition-all hover:bg-white/20">
          <Icon name="padel" size={20} />{t('nav.padel')}
        </a>
        <a href={localizePath(lang, '/futbol-7')} class="inline-flex items-center gap-2 rounded-full bg-white/10 px-6 py-3 font-display font-semibold text-white ring-1 ring-white/25 backdrop-blur transition-all hover:bg-white/20">
          <Icon name="football" size={20} />{t('nav.football')}
        </a>
      </div>

      <!-- 4) Dirección y demás info -->
      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/85">
        <a href={club.mapsLink} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-gold">
          <Icon name="pin" size={16} />{club.address}
        </a>
        <a href={`tel:${club.phone}`} class="flex items-center gap-2 hover:text-gold">
          <Icon name="phone" size={16} />{club.phoneDisplay}
        </a>
        <a href={`mailto:${club.email}`} class="flex items-center gap-2 hover:text-gold">
          <Icon name="mail" size={16} />{club.email}
        </a>
        <a href={`https://wa.me/${club.whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-semibold text-[#25D366] hover:brightness-110">
          <Icon name="whatsapp" size={16} />WhatsApp
        </a>
      </div>

      <!-- 5) Reservar pista -->
      <div class="mt-7">
        <a href={club.booking} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-gold px-8 py-4 font-display text-lg font-bold text-navy shadow-lg shadow-gold/25 transition-all hover:-translate-y-0.5 hover:bg-accent-dark">
          {t('hero.ctaPrimary')}
          <Icon name="arrow" size={18} />
        </a>
      </div>

      <!-- 6) The home of The Padel Performance Method® -->
      <p class="mt-6 font-display text-sm font-semibold uppercase tracking-wide text-gold sm:text-base">{t('hero.brandline')}</p>
    </div>
  </div>
</section>

<script>
  const bg = document.getElementById('hero-bg');
  if (bg && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      if (y < window.innerHeight) bg.style.transform = `translate3d(0, ${y * 0.25}px, 0)`;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
  }
</script>
