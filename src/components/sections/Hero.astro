---
import { Image } from 'astro:assets';
import Icon from '../ui/Icon.astro';
import { useTranslations, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';
import { img } from '../../lib/images';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative flex min-h-[92vh] items-center justify-center overflow-hidden bg-navy text-center">
  <!-- Fondo aéreo del club con parallax -->
  <div id="hero-bg" class="absolute inset-0 will-change-transform">
    <Image
      src={img('aerial-hero.jpg')}
      alt="Magaluf Sport Club - vista aérea"
      widths={[768, 1280, 1920, 2400]}
      sizes="100vw"
      class="h-[115%] w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="absolute inset-0 bg-navy/75"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-navy/40"></div>

  <div class="relative mx-auto w-full max-w-3xl px-5 pt-28 pb-16 text-white sm:px-8" data-reveal>
    <!-- Logo protagonista (ya contiene el nombre) -->
    <Image src={img('logo.png')} alt="Magaluf Sport Club" width={260} height={228} class="mx-auto h-28 w-auto sm:h-40" loading="eager" />

    <h1 class="mt-6 text-2xl font-bold leading-tight sm:text-3xl md:text-4xl">{t('hero.title')}</h1>
    <p class="mt-3 font-display text-sm font-semibold uppercase tracking-wide text-gold sm:text-base">{t('hero.brandline')}</p>

    <!-- Contacto directo -->
    <div class="mt-7 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-white/85">
      <a href={club.mapsLink} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-gold">
        <Icon name="pin" size={16} />{club.address}
      </a>
      <a href={`tel:${club.phone}`} class="flex items-center gap-2 hover:text-gold">
        <Icon name="phone" size={16} />{club.phoneDisplay}
      </a>
      <a href={`mailto:${club.email}`} class="flex items-center gap-2 hover:text-gold">
        <Icon name="mail" size={16} />{club.email}
      </a>
    </div>

    <!-- Acceso rápido: Playtomic + WhatsApp -->
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href={club.booking} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-gold px-8 py-4 font-display text-lg font-bold text-navy shadow-lg shadow-gold/25 transition-all hover:-translate-y-0.5 hover:bg-accent-dark">
        {t('hero.ctaPrimary')}
        <Icon name="arrow" size={18} />
      </a>
      <a href={`https://wa.me/${club.whatsapp}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-[#25D366] px-8 py-4 font-display text-lg font-bold text-white shadow-lg transition-all hover:-translate-y-0.5 hover:brightness-110">
        <Icon name="whatsapp" size={20} />WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  const bg = document.getElementById('hero-bg');
  if (bg && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      if (y < window.innerHeight) bg.style.transform = `translate3d(0, ${y * 0.25}px, 0)`;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
  }
</script>
