---
import { legalUpdated } from '../../content/legal';

interface Section {
  heading?: string;
  paragraphs?: string[];
  list?: string[];
}
interface Props {
  doc: { title: string; sections: Section[] };
  updatedLabel: string;
}
const { doc, updatedLabel } = Astro.props;
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    {
      doc.sections.map((s) => (
        <div class="mt-8 first:mt-0">
          {s.heading && <h2 class="font-display text-xl font-bold text-navy">{s.heading}</h2>}
          {s.paragraphs?.map((p) => <p class="mt-3 leading-relaxed text-muted">{p}</p>)}
          {s.list && (
            <ul class="mt-3 space-y-1.5">
              {s.list.map((li) => (
                <li class="flex gap-2 text-muted"><span class="text-gold">·</span><span>{li}</span></li>
              ))}
            </ul>
          )}
        </div>
      ))
    }
    <p class="mt-12 border-t border-line pt-6 text-sm text-muted">{updatedLabel}: {legalUpdated}</p>
  </div>
</section>
