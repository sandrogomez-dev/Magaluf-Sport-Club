---
import { Image } from 'astro:assets';
import Section from '../ui/Section.astro';
import Heading from '../ui/Heading.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, localizePath, type Lang } from '../../i18n/ui';
import { img } from '../../lib/images';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
  { icon: 'trophy', label: t('events.tournaments') },
  { icon: 'kids', label: t('events.kids') },
  { icon: 'events', label: t('events.parties') },
  { icon: 'building', label: t('events.company') },
];
---

<Section bg="surface">
  <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
    <!-- Imagen de comunidad/eventos -->
    <div class="relative order-2 lg:order-1" data-reveal>
      <div class="overflow-hidden rounded-[1.5rem] shadow-2xl shadow-navy/15">
        <Image
          src={img('events-group.jpg')}
          alt={t('events.title')}
          widths={[500, 900]}
          sizes="(min-width:1024px) 50vw, 100vw"
          class="aspect-[4/3] w-full object-cover"
        />
      </div>
    </div>

    <div class="order-1 lg:order-2">
      <Heading eyebrow={t('events.eyebrow')} title={t('events.title')} intro={t('events.desc')} />

      <div class="mt-8 grid grid-cols-2 gap-4">
        {
          items.map((it, i) => (
            <div
              class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-line/60 transition-all hover:-translate-y-1 hover:ring-gold"
              data-reveal
              style={`transition-delay:${i * 70}ms`}
            >
              <span class="grid h-11 w-11 place-items-center rounded-full bg-brand/10 text-brand">
                <Icon name={it.icon} size={22} />
              </span>
              <p class="mt-3 font-display text-sm font-semibold text-ink">{it.label}</p>
            </div>
          ))
        }
      </div>

      <a
        href={localizePath(lang, '/eventos')}
        class="mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-brand px-7 py-3.5 font-display font-semibold text-white shadow-lg shadow-brand/20 transition-all hover:-translate-y-0.5 hover:bg-brand-dark"
      >
        {t('events.cta')}
        <Icon name="arrow" size={18} />
      </a>
    </div>
  </div>
</Section>
