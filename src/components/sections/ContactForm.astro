---
import Section from '../ui/Section.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, getDict, localizePath, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const services: string[] = getDict(lang).form.services;
const field =
  'w-full rounded-xl border border-line bg-surface px-4 py-3 text-ink outline-none transition-colors focus:border-brand focus:bg-white';
---

<Section bg="white" id="formulario">
  <div class="grid items-start gap-10 lg:grid-cols-5 lg:gap-14">
    <div class="lg:col-span-2" data-reveal>
      <span class="eyebrow-line text-sm font-semibold uppercase tracking-[0.18em] text-brand">{t('nav.contact')}</span>
      <h2 class="mt-4 text-3xl font-bold sm:text-4xl">{t('form.title')}</h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">{t('form.intro')}</p>

      <div class="mt-6 space-y-2 text-ink">
        <a href={`tel:${club.phone}`} class="flex items-center gap-3 hover:text-brand"><Icon name="phone" size={18} />{club.phoneDisplay}</a>
        <a href={`mailto:${club.email}`} class="flex items-center gap-3 hover:text-brand"><Icon name="check" size={18} />{club.email}</a>
        <p class="flex items-center gap-3 text-muted"><Icon name="pin" size={18} />{club.address}</p>
      </div>
    </div>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action={localizePath(lang, '/gracias')}
      class="lg:col-span-3 rounded-[1.5rem] bg-surface p-6 ring-1 ring-line sm:p-8"
      data-reveal
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden"><label>No rellenar: <input name="bot-field" /></label></p>

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1.5 block text-sm font-semibold text-navy">{t('form.name')}</span>
          <input type="text" name="nombre" required class={field} />
        </label>
        <label class="block">
          <span class="mb-1.5 block text-sm font-semibold text-navy">{t('form.email')}</span>
          <input type="email" name="email" required class={field} />
        </label>
        <label class="block">
          <span class="mb-1.5 block text-sm font-semibold text-navy">{t('form.phone')}</span>
          <input type="tel" name="telefono" class={field} />
        </label>
        <label class="block">
          <span class="mb-1.5 block text-sm font-semibold text-navy">{t('form.service')}</span>
          <select name="servicio" class={field}>
            {services.map((s) => <option value={s}>{s}</option>)}
          </select>
        </label>
      </div>

      <label class="mt-4 block">
        <span class="mb-1.5 block text-sm font-semibold text-navy">{t('form.message')}</span>
        <textarea name="mensaje" rows="4" required class={field}></textarea>
      </label>

      <button
        type="submit"
        class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-full bg-brand px-7 py-3.5 font-display font-semibold text-white transition-all hover:-translate-y-0.5 hover:bg-brand-dark sm:w-auto"
      >
        {t('form.submit')}<Icon name="arrow" size={18} />
      </button>
      <p class="mt-3 text-xs text-muted">{t('form.note')}</p>
    </form>
  </div>
</Section>
