---
import { Image } from 'astro:assets';
import { img } from '../../lib/images';

interface Props {
  image: string;
  eyebrow?: string;
  title: string;
}
const { image, eyebrow, title } = Astro.props;
---

<section class="relative flex min-h-[460px] items-center justify-center overflow-hidden bg-navy py-24 grain">
  <div class="parallax-band absolute inset-0 will-change-transform">
    <Image
      src={img(image)}
      alt=""
      widths={[768, 1280, 1920]}
      sizes="100vw"
      class="h-[125%] w-full object-cover"
      loading="lazy"
    />
  </div>
  <div class="absolute inset-0 bg-navy/65"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-navy via-transparent to-navy/40"></div>

  <div class="relative mx-auto max-w-3xl px-5 text-center text-white" data-reveal>
    {eyebrow && (
      <span class="text-sm font-semibold uppercase tracking-[0.2em] text-gold">{eyebrow}</span>
    )}
    <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl md:text-5xl">{title}</h2>
  </div>
</section>

<script>
  const band = document.querySelector<HTMLElement>('.parallax-band');
  if (band && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    const update = () => {
      const rect = band.parentElement!.getBoundingClientRect();
      const offset = (rect.top - window.innerHeight / 2) * -0.08;
      band.style.transform = `translate3d(0, ${offset}px, 0)`;
      ticking = false;
    };
    update();
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
  }
</script>
