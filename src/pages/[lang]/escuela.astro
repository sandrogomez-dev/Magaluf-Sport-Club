---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/sections/PageIntro.astro';
import Section from '../../components/ui/Section.astro';
import Heading from '../../components/ui/Heading.astro';
import Icon from '../../components/ui/Icon.astro';
import MethodTeaser from '../../components/sections/MethodTeaser.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { languages, useTranslations, getDict, localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const dict = getDict(lang);
const s = dict.school;
const contact = localizePath(lang, '/contacto');
const icons = ['kids', 'users', 'school', 'trophy', 'badge'];
---

<BaseLayout lang={lang} title={dict.seo.school.title} description={dict.seo.school.description}>
  <PageIntro eyebrow={s.eyebrow} title={s.title} intro={s.tagline} image="coaches.jpg" />

  <Section bg="white">
    <p class="mx-auto max-w-3xl text-center text-xl leading-relaxed text-muted" data-reveal>{s.intro}</p>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        s.programs.map((p: any, i: number) => (
          <div class="flex flex-col rounded-[1.5rem] bg-surface p-7 ring-1 ring-line/60 transition-all hover:-translate-y-1 hover:ring-gold" data-reveal style={`transition-delay:${i * 70}ms`}>
            <span class="grid h-12 w-12 place-items-center rounded-full bg-navy text-gold">
              <Icon name={icons[i] ?? 'school'} size={24} />
            </span>
            <h3 class="mt-4 font-display text-lg font-bold text-ink">{p.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-snug text-muted">{p.desc}</p>
            <a href={contact} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:text-brand-dark">
              {s.cta}<Icon name="arrow" size={15} />
            </a>
          </div>
        ))
      }
    </div>
  </Section>

  <MethodTeaser lang={lang} />
  <CtaBanner lang={lang} />
</BaseLayout>
