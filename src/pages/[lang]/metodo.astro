---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/sections/PageIntro.astro';
import Section from '../../components/ui/Section.astro';
import Heading from '../../components/ui/Heading.astro';
import Icon from '../../components/ui/Icon.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { languages, useTranslations, getDict, localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const dict = getDict(lang);
const m = dict.method;
const contact = localizePath(lang, '/contacto');
---

<BaseLayout lang={lang} title={dict.seo.method.title} description={dict.seo.method.description}>
  <PageIntro eyebrow={m.eyebrow} title={m.title} intro={m.tagline} image="padel-coaching.jpg" />

  <!-- Introducción -->
  <Section bg="white">
    <p class="mx-auto max-w-3xl text-center text-xl leading-relaxed text-muted" data-reveal>{m.intro}</p>
  </Section>

  <!-- 5 pilares -->
  <Section bg="surface">
    <Heading title={m.pillarsTitle} align="center" />
    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {
        m.pillars.map((p: any, i: number) => (
          <div class="rounded-[1.25rem] bg-white p-6 ring-1 ring-line/60" data-reveal style={`transition-delay:${i * 70}ms`}>
            <span class="font-display text-3xl font-extrabold text-gold">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="mt-3 font-display text-lg font-bold uppercase tracking-wide text-navy">{p.title}</h3>
            <p class="mt-2 text-sm leading-snug text-muted">{p.desc}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Tecnología -->
  <Section bg="white">
    <Heading title={m.techTitle} align="center" />
    <div class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-2">
      {
        m.tech.map((tch: any) => (
          <div class="rounded-[1.5rem] border border-line bg-surface p-8" data-reveal>
            <span class="grid h-12 w-12 place-items-center rounded-full bg-navy text-gold">
              <Icon name="chip" size={24} />
            </span>
            <h3 class="mt-4 font-display text-2xl font-extrabold text-navy">{tch.name}</h3>
            <p class="mt-2 leading-relaxed text-muted">{tch.desc}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- Estándares de calidad -->
  <section class="relative overflow-hidden bg-navy py-20 text-white sm:py-24 grain">
    <div class="relative mx-auto max-w-5xl px-5 sm:px-8">
      <h2 class="text-center text-3xl font-extrabold sm:text-4xl" data-reveal>{m.standardsTitle}</h2>
      <div class="mx-auto mt-12 grid max-w-3xl gap-3 sm:grid-cols-2">
        {
          m.standards.map((s: string, i: number) => (
            <div class="flex items-center gap-3 rounded-xl bg-white/10 px-5 py-4 ring-1 ring-white/10" data-reveal style={`transition-delay:${i * 50}ms`}>
              <span class="text-gold"><Icon name="check" size={20} /></span>
              <span class="font-medium">{s}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Programas / Performance Camps -->
  <Section bg="surface">
    <Heading title={m.campsTitle} intro={m.campsIntro} align="center" />
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        m.camps.map((c: any, i: number) => (
          <div class="flex flex-col rounded-[1.25rem] bg-white p-6 ring-1 ring-line/60 transition-all hover:-translate-y-1 hover:ring-gold" data-reveal style={`transition-delay:${i * 70}ms`}>
            <span class="w-fit rounded-full bg-gold px-3 py-1 text-xs font-bold uppercase tracking-wide text-navy">{c.label}</span>
            <h3 class="mt-4 font-display text-lg font-bold text-navy">{c.name}</h3>
            <p class="mt-2 flex-1 text-sm leading-snug text-muted">{c.goal}</p>
            <a href={contact} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:text-brand-dark">
              {m.cta}<Icon name="arrow" size={15} />
            </a>
          </div>
        ))
      }
    </div>
    <p class="mt-8 text-center text-sm text-muted" data-reveal>{m.campsNote}</p>
  </Section>

  <CtaBanner lang={lang} />
</BaseLayout>
