---
import { languages, localizePath, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
const target = `${localizePath(lang, '/padel')}#metodo`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>The Padel Performance Method®</title>
  </head>
  <body>
    <a href={target}>The Padel Performance Method®</a>
  </body>
</html>
