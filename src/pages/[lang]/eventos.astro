---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/sections/PageIntro.astro';
import EventsTeaser from '../../components/sections/EventsTeaser.astro';
import Holidays from '../../components/sections/Holidays.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { languages, useTranslations, getDict, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const dict = getDict(lang);
---

<BaseLayout lang={lang} title={dict.seo.events.title} description={dict.seo.events.description}>
  <PageIntro eyebrow={t('nav.events')} title={dict.pages.events.title} intro={dict.pages.events.intro} image="events-group.jpg" />
  <EventsTeaser lang={lang} />
  <Holidays lang={lang} />
  <CtaBanner lang={lang} />
</BaseLayout>
