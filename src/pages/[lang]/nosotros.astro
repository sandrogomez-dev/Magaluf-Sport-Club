---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/sections/PageIntro.astro';
import Section from '../../components/ui/Section.astro';
import StatsBar from '../../components/sections/StatsBar.astro';
import Gallery from '../../components/sections/Gallery.astro';
import LocationContact from '../../components/sections/LocationContact.astro';
import { languages, useTranslations, getDict, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const dict = getDict(lang);
const values: { title: string; desc: string }[] = dict.pages.about.values;
---

<BaseLayout lang={lang} title={dict.seo.about.title} description={dict.seo.about.description}>
  <PageIntro eyebrow={t('nav.about')} title={dict.pages.about.title} intro={dict.pages.about.intro} image="aerial-sign.jpg" />

  <Section bg="white">
    <p class="mx-auto max-w-3xl text-center text-xl leading-relaxed text-muted" data-reveal>
      {dict.pages.about.body}
    </p>

    <div class="mt-14 grid gap-6 sm:grid-cols-3">
      {
        values.map((v, i) => (
          <div class="rounded-[1.25rem] bg-surface p-8 ring-1 ring-line/60" data-reveal style={`transition-delay:${i * 80}ms`}>
            <h3 class="font-display text-xl font-bold text-brand">{v.title}</h3>
            <p class="mt-3 leading-relaxed text-muted">{v.desc}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <StatsBar lang={lang} />
  <Gallery lang={lang} />
  <LocationContact lang={lang} />
</BaseLayout>
