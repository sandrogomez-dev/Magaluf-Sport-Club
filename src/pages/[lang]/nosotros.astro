---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/sections/PageIntro.astro';
import FeatureSplit from '../../components/sections/FeatureSplit.astro';
import Heading from '../../components/ui/Heading.astro';
import Icon from '../../components/ui/Icon.astro';
import StatsBar from '../../components/sections/StatsBar.astro';
import Gallery from '../../components/sections/Gallery.astro';
import LocationContact from '../../components/sections/LocationContact.astro';
import { img } from '../../lib/images';
import { languages, useTranslations, getDict, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const dict = getDict(lang);

const amenities = [
  { icon: 'cafe', label: t('pages.about.amenities.cafe') },
  { icon: 'shop', label: t('pages.about.amenities.shop') },
  { icon: 'lockers', label: t('pages.about.amenities.lockers') },
  { icon: 'parking', label: t('pages.about.amenities.parking') },
];
---

<BaseLayout lang={lang} title={dict.seo.about.title} description={dict.seo.about.description}>
  <PageIntro eyebrow={t('nav.about')} title={dict.pages.about.title} intro={dict.pages.about.intro} image="aerial-sign.jpg" />

  <!-- Historia, con la foto del Equipo A arriba -->
  <FeatureSplit
    eyebrow={t('pages.about.story.eyebrow')}
    title={t('pages.about.story.title')}
    desc={dict.pages.about.body}
    image="team-a.jpg"
  />

  <!-- Mucho más que pádel -->
  <FeatureSplit
    eyebrow={t('pages.about.muchomas.eyebrow')}
    title={t('pages.about.muchomas.title')}
    desc={t('pages.about.muchomas.desc')}
    image="community-team.jpg"
    reverse
    bg="surface"
  />

  <!-- Servicios del club, sobre plano aéreo -->
  <section class="relative overflow-hidden bg-navy py-20 text-white sm:py-24 grain">
    <Image src={img('aerial-top-day.jpg')} alt="" widths={[768, 1280, 1920]} sizes="100vw" class="absolute inset-0 h-full w-full object-cover opacity-25" loading="lazy" />
    <div class="absolute inset-0 bg-navy/70"></div>
    <div class="relative mx-auto max-w-5xl px-5 sm:px-8">
      <h2 class="text-center text-3xl font-extrabold sm:text-4xl" data-reveal>{t('pages.about.amenities.title')}</h2>
      <div class="mx-auto mt-12 grid max-w-3xl grid-cols-2 gap-4 sm:grid-cols-4">
        {
          amenities.map((a, i) => (
            <div class="flex flex-col items-center gap-3 rounded-2xl bg-white/10 px-4 py-7 text-center ring-1 ring-white/15 backdrop-blur-sm" data-reveal style={`transition-delay:${i * 60}ms`}>
              <span class="grid h-12 w-12 place-items-center rounded-full bg-gold text-navy">
                <Icon name={a.icon} size={24} />
              </span>
              <span class="text-sm font-semibold">{a.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Nuestro equipo (profes, con foto real) -->
  <section class="bg-surface py-20 sm:py-28">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <Heading
        eyebrow={t('pages.about.team.eyebrow')}
        title={t('pages.about.team.title')}
        intro={t('pages.about.team.intro')}
        align="center"
      />
      <div class="mx-auto mt-12 grid max-w-2xl gap-8 sm:grid-cols-2">
        {
          club.team.map((m, i) => (
            <div class="overflow-hidden rounded-[1.5rem] bg-white shadow-sm ring-1 ring-line/60 transition-all hover:-translate-y-1 hover:shadow-xl" data-reveal style={`transition-delay:${i * 90}ms`}>
              <Image
                src={img(m.photo)}
                alt={m.name}
                widths={[400, 700]}
                sizes="(min-width:640px) 50vw, 100vw"
                class="aspect-[4/5] w-full object-cover object-top"
              />
              <div class="p-6">
                <p class="font-display text-xl font-bold text-ink">{m.name}</p>
                <p class="mt-1 text-sm font-medium text-brand">{t(`pages.about.team.roles.${m.roleKey}`)}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <StatsBar lang={lang} />
  <Gallery lang={lang} />
  <LocationContact lang={lang} />
</BaseLayout>
