---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Gateway from '../../components/sections/Gateway.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import LocationContact from '../../components/sections/LocationContact.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { languages, useTranslations, getDict, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const dict = getDict(lang);
---

<BaseLayout lang={lang} title={dict.seo.home.title} description={dict.seo.home.description}>
  <Hero lang={lang} />
  <Gateway lang={lang} />
  <Testimonials lang={lang} />
  <LocationContact lang={lang} />
  <CtaBanner lang={lang} />
</BaseLayout>
