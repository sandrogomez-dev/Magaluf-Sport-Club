---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/sections/PageIntro.astro';
import FeatureSplit from '../../components/sections/FeatureSplit.astro';
import Section from '../../components/ui/Section.astro';
import Heading from '../../components/ui/Heading.astro';
import Icon from '../../components/ui/Icon.astro';
import PhotoBand from '../../components/sections/PhotoBand.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { languages, useTranslations, getDict, type Lang } from '../../i18n/ui';
import { club } from '../../content/club';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const dict = getDict(lang);
---

<BaseLayout lang={lang} title={dict.seo.football.title} description={dict.seo.football.description}>
  <PageIntro eyebrow={t('nav.football')} title={dict.pages.football.title} intro={dict.pages.football.intro} image="football-aerial.jpg" />

  <FeatureSplit
    eyebrow={t('footballSection.eyebrow')}
    title={t('footballSection.title')}
    desc={t('footballSection.desc')}
    features={dict.footballSection.features}
    image="football-pitch.jpg"
    ctaLabel={t('footballSection.cta')}
    ctaHref={club.booking}
    ctaExternal
  />

  <Section bg="surface">
    <Heading title={t('footballHub.title')} intro={t('footballHub.intro')} align="center" />
    <div class="mx-auto mt-12 grid max-w-3xl grid-cols-2 gap-4 sm:grid-cols-3">
      {
        dict.footballHub.items.map((item: string, i: number) => (
          <div class="flex items-center gap-3 rounded-2xl bg-white p-5 ring-1 ring-line/60" data-reveal style={`transition-delay:${i * 50}ms`}>
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-brand/10 text-brand"><Icon name="football" size={20} /></span>
            <span class="text-sm font-semibold text-ink">{item}</span>
          </div>
        ))
      }
    </div>
    <PhotoBand images={['football-aerial.jpg', 'football-pitch.jpg', 'club-overview.jpg']} class="mt-12" />
  </Section>

  <CtaBanner lang={lang} />
</BaseLayout>
